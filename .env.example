APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Indicatif sans + (ex. 221 pour le Sénégal) si les numéros clients sont au format local 07…
WHATSAPP_DEFAULT_COUNTRY_CODE=221
# Modèles WhatsApp Cloud (Meta) — optionnel. Code langue du modèle approuvé (ex. fr, en_US).
# WHATSAPP_TEMPLATE_MODE=message → 1 variable « corps » = message complet (votre modèle Meta doit avoir 1 placeholder body).
# WHATSAPP_TEMPLATE_MODE=fields → 3 variables : date (jj/mm/aaaa), heure, phrase courte (confirmé / refusé).
#WHATSAPP_TEMPLATE_NAME=
#WHATSAPP_TEMPLATE_CONFIRM_NAME=
#WHATSAPP_TEMPLATE_REFUSE_NAME=
WHATSAPP_TEMPLATE_LANG=fr
WHATSAPP_TEMPLATE_MODE=message
# Si true et que l’envoi « template » échoue, retente en message texte libre (souvent refusé hors fenêtre 24h).
WHATSAPP_TEMPLATE_FALLBACK_TEXT=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
